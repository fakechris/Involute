{
  "name": "involute",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm -r build",
    "compose:down": "docker compose down --remove-orphans",
    "compose:up": "docker compose up --build -d db server web",
    "compose:prod:build": "docker compose --env-file .env.production -f docker-compose.prod.yml build",
    "compose:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down --remove-orphans",
    "compose:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up --build -d",
    "docker:build": "docker compose build",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @involute/shared test --run && pnpm --filter @involute/server test --run && pnpm --filter @involute/cli test --run && pnpm --filter @involute/web test --run",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1"
  }
}
