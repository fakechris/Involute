# Involute production environment variables
# Copy this to .env on the server and fill in real values.
# NEVER rsync your local .env to the server — use scripts/deploy.sh instead.

DATABASE_URL=postgresql://user:password@127.0.0.1:4202/involute
AUTH_TOKEN=changeme-set-your-token
PORT=4200

# These are required for production (Nginx static serving instead of Vite dev server)
INVOLUTE_WEB_BUILD_TARGET=web
VITE_INVOLUTE_GRAPHQL_URL=/graphql
INTERNAL_SERVER_ORIGIN=http://server:4200
SEED_DATABASE=false
