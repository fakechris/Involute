generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  ADMIN
  USER
}

enum TeamVisibility {
  PRIVATE
  PUBLIC
}

enum TeamMembershipRole {
  VIEWER
  EDITOR
  OWNER
}

enum WorkflowStateType {
  BACKLOG
  UNSTARTED
  STARTED
  COMPLETED
  CANCELED
}

model Team {
  id              String          @id @default(uuid()) @db.Uuid
  key             String          @unique
  name            String
  visibility      TeamVisibility  @default(PRIVATE)
  nextIssueNumber Int             @default(1)
  states          WorkflowState[]
  issues          Issue[]
  memberships     TeamMembership[]
  projects        Project[]
  cycles          Cycle[]

  @@index([key])
}

model WorkflowState {
  id       String            @id @default(uuid()) @db.Uuid
  name     String
  type     WorkflowStateType @default(UNSTARTED)
  position Int               @default(0)
  teamId   String            @db.Uuid
  team     Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues   Issue[]

  @@unique([id, teamId])
  @@unique([teamId, name])
  @@index([teamId])
}

model IssueLabel {
  id     String  @id @default(uuid()) @db.Uuid
  name   String  @unique
  issues Issue[]
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  email          String    @unique
  avatarUrl      String?
  googleSubject  String?   @unique
  globalRole     GlobalRole @default(USER)
  assignedIssues Issue[]   @relation("IssueAssignee")
  comments       Comment[]
  memberships    TeamMembership[]
  sessions       Session[]
  ledProjects    Project[] @relation("ProjectLead")
  uploads        Attachment[] @relation("Uploads")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TeamMembership {
  id        String             @id @default(uuid()) @db.Uuid
  teamId    String             @db.Uuid
  userId    String             @db.Uuid
  role      TeamMembershipRole
  createdAt DateTime           @default(now())
  team      Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Issue {
  id          String         @id @default(uuid()) @db.Uuid
  identifier  String         @unique
  title       String
  description String?
  stateId     String         @db.Uuid
  state       WorkflowState  @relation(fields: [stateId, teamId], references: [id, teamId], onDelete: Restrict)
  assigneeId  String?        @db.Uuid
  assignee    User?          @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  parentId    String?        @db.Uuid
  parent      Issue?         @relation("IssueParentChild", fields: [parentId], references: [id], onDelete: SetNull)
  children    Issue[]        @relation("IssueParentChild")
  teamId      String         @db.Uuid
  team        Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  priority    Int            @default(0)
  labels      IssueLabel[]
  comments    Comment[]
  projectId   String?        @db.Uuid
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  cycleId     String?        @db.Uuid
  cycle       Cycle?         @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  attachments Attachment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([teamId])
  @@index([stateId, teamId])
  @@index([stateId])
  @@index([assigneeId])
  @@index([parentId])
  @@index([projectId])
  @@index([cycleId])
}

model Comment {
  id          String       @id @default(uuid()) @db.Uuid
  body        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  issueId     String       @db.Uuid
  issue       Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId      String       @db.Uuid
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([issueId, createdAt])
  @@index([userId])
}

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  color       String    @default("#6366f1")
  status      String    @default("planned")
  targetDate  DateTime?
  teamId      String    @db.Uuid
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leadId      String?   @db.Uuid
  lead        User?     @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  issues      Issue[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([teamId])
}

model Cycle {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  number    Int
  startsAt  DateTime
  endsAt    DateTime
  teamId    String   @db.Uuid
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues    Issue[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  filename   String
  mimeType   String
  size       Int
  url        String
  issueId    String?  @db.Uuid
  issue      Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  commentId  String?  @db.Uuid
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  uploaderId String   @db.Uuid
  uploader   User     @relation("Uploads", fields: [uploaderId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([issueId])
  @@index([commentId])
  @@index([uploaderId])
}

model LegacyLinearMapping {
  id         String   @id @default(uuid()) @db.Uuid
  oldId      String
  newId      String
  entityType String
  migratedAt DateTime @default(now())

  @@unique([oldId, entityType])
  @@unique([newId, entityType])
  @@index([entityType])
}
