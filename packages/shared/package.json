{
  "name": "@turnkeyai/involute-shared",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./import-format": {
      "types": "./dist/import-format.d.ts",
      "import": "./dist/import-format.js",
      "default": "./dist/import-format.js"
    },
    "./viewer-assertion": {
      "types": "./dist/viewer-assertion.d.ts",
      "import": "./dist/viewer-assertion.js",
      "default": "./dist/viewer-assertion.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest --config vitest.config.ts --passWithNoTests",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
