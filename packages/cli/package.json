{
  "name": "@involute/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "involute": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest --config vitest.config.ts --passWithNoTests",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@involute/server": "workspace:*",
    "@prisma/client": "^6.7.0",
    "commander": "^14.0.1",
    "dotenv": "^16.6.1",
    "graphql": "^16.11.0",
    "graphql-request": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
