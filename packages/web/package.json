{
  "name": "@involute/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json --noEmit && pnpm exec vite build",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "sh -c 'export NODE_OPTIONS=--max-old-space-size=8192; for file in $(rg --files src -g \"*.test.ts\" -g \"*.test.tsx\" | sort); do pnpm exec vitest --config vitest.config.ts --reporter=verbose --passWithNoTests --run \"$file\" || exit $?; done'",
    "lint": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@apollo/client": "^4.0.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "graphql": "^16.11.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^4.0.8"
  }
}
