DATABASE_URL=postgresql://involute:involute@127.0.0.1:5434/involute?schema=public
DB_BIND_ADDRESS=127.0.0.1
DB_PORT={{ involute_db_port | default(5434) }}
SERVER_BIND_ADDRESS={{ involute_bind_address }}
WEB_BIND_ADDRESS={{ involute_bind_address }}
INVOLUTE_WEB_BUILD_TARGET=web

AUTH_TOKEN={{ involute_auth_token }}
VITE_INVOLUTE_GRAPHQL_URL=/graphql
INTERNAL_SERVER_ORIGIN=http://server:4200
WEB_PROXY_AUTHORIZATION=Bearer {{ involute_auth_token }}
VIEWER_ASSERTION_SECRET={{ involute_viewer_assertion_secret }}
ALLOW_ADMIN_FALLBACK={{ 'true' if involute_allow_admin_fallback | default(false) | bool else 'false' }}
APP_ORIGIN={{ involute_app_origin }}
PORT=4200

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

ADMIN_EMAIL_ALLOWLIST={{ involute_admin_email_allowlist | default('') }}
SEED_DATABASE={{ 'true' if involute_seed_database | bool else 'false' }}
SEED_DEFAULT_ADMIN={{ 'true' if involute_seed_default_admin | default(false) | bool else 'false' }}
