APP_DOMAIN={{ involute_app_domain }}
APP_ORIGIN={{ involute_app_origin }}

POSTGRES_DB={{ involute_postgres_db | default('involute') }}
POSTGRES_USER={{ involute_postgres_user | default('involute') }}
POSTGRES_PASSWORD={{ involute_postgres_password }}

AUTH_TOKEN={{ involute_auth_token }}
VIEWER_ASSERTION_SECRET={{ involute_viewer_assertion_secret }}
SESSION_TTL_SECONDS={{ involute_session_ttl_seconds | default(2592000) }}

ADMIN_EMAIL_ALLOWLIST={{ involute_admin_email_allowlist | default('') }}
SEED_DATABASE={{ 'true' if involute_seed_database | bool else 'false' }}

GOOGLE_OAUTH_CLIENT_ID={{ involute_google_oauth_client_id | default('') }}
GOOGLE_OAUTH_CLIENT_SECRET={{ involute_google_oauth_client_secret | default('') }}
GOOGLE_OAUTH_REDIRECT_URI={{ involute_google_oauth_redirect_uri | default('') }}
